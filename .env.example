# Telegram API client credentials from https://my.telegram.org
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Saved Telethon session path. Mount this as a persistent Docker volume.
TELEGRAM_SESSION_PATH=/app/data/telegram.session

# Comma-separated source channel usernames or numeric IDs, for example deals_channel,-100123456789.
SOURCE_CHANNELS=

# Bot token for publishing to the final channel.
TELEGRAM_BOT_TOKEN=

# Destination channel username or numeric ID.
DESTINATION_CHANNEL=

# Validator mode: local or http.
VALIDATOR_MODE=local

# Required only when VALIDATOR_MODE=http.
VALIDATOR_URL=
VALIDATOR_TIMEOUT_SECONDS=10

# Keep only short operational memory.
RETENTION_DAYS=3

# 0 means do not import old messages on startup.
STARTUP_BACKFILL_LIMIT=0

# Logging verbosity.
LOG_LEVEL=INFO

# Storage path.
DATABASE_URL=sqlite:////app/data/scappy.sqlite3

# Keep true until Telegram publish is intentionally tested.
DRY_RUN=true
